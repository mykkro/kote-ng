<?xml version='1.0' encoding='utf-8'?>
<widget id="org.mykkro.kote.therapy" version="1.0.12" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Kote</name>
    <description>Cognitive testing</description>
    <author email="myrousz@gmail.com">Myrousz</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
